theme_override_colors/font_color = Color(0.75, 0.72, 0.85, 1)
text = "六边形战棋 RPG"
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="CenterLayer/MenuColumn"]
custom_minimum_size = Vector2(0, 8)
layout_mode = 2

[node name="ContinueButton" type="Button" parent="CenterLayer/MenuColumn"]
custom_minimum_size = Vector2(280, 44)
